API_KEYS=test-free-key
BASIC_KEYS=test-basic-key
PRO_KEYS=test-pro-key
ENTERPRISE_KEYS=test-ent-key
RAPIDAPI_PROXY_SECRET=
PORT=8000
ENV=development
DISABLED_STATES=NY
CACHE_TTL_VERIFY=1200
CACHE_TTL_SEARCH=900
# REQUIRED IN PRODUCTION: Redis connection string for shared rate limiting and monthly quotas.
# Without Redis:
#   - Per-minute rate limits are in-memory and per-process (multi-worker deployments get separate buckets)
#   - Monthly quotas are NOT enforced (documented limits in pricing will not be applied)
#   - A WARNING is logged at startup when REDIS_URL is unset
# Railway sets this automatically when you add a Redis service.
# Leave unset for local dev only.
REDIS_URL=
# Seed license numbers for /probe/verify endpoint (full parse probe).
# Set to a known-good license number per state. If unset, /probe/verify returns 503 for that state.
PROBE_LICENSE_CA=
PROBE_LICENSE_TX=
PROBE_LICENSE_FL=
